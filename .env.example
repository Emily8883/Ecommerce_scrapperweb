# E-Commerces WebScraper Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# AI Integration (Existing)
# =============================================================================

# Gemini API Keys (comma-separated list for automatic failover using named entries)
# Format: {OwnerName}:{API_KEY},{OwnerName}:{API_KEY},...,{OwnerName}:{API_KEY}
# Example: Main:AIza...,Backup:AIza...,University:AIza...
# The system iterates in order and switches keys when rate limits or failures occur
# OwnerName is used for logging, monitoring, and debugging purposes
# Whitespace around names and keys is ignored; malformed entries are skipped
GEMINI_API_KEY=Main:your_gemini1_api_key_here,Backup:your_gemini2_api_key_here,University:your_gemini3_api_key_here

# =============================================================================
# Browser Authentication (NEW - Required for Shopee and Shein)
# =============================================================================

# Path to your Chrome user data directory with authenticated sessions
# Windows: C:/Users/YourUsername/AppData/Local/Google/Chrome/User Data
# macOS: /Users/YourUsername/Library/Application Support/Google/Chrome
# Linux: /home/YourUsername/.config/google-chrome
# Note: Use forward slashes (/) even on Windows
CHROME_PROFILE_PATH=

# Path to Chrome executable (optional - leave empty for default location)
# Windows: C:/Program Files/Google/Chrome/Application/chrome.exe
# macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux: /usr/bin/google-chrome
CHROME_EXECUTABLE_PATH=

# Run browser in headless mode (True/False)
# Set to False for debugging, True for production
HEADLESS=False
